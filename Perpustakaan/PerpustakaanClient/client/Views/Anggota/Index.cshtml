@model List<client.Models.AnggotaModel>
@{
    ViewBag.Title = "Daftar Anggota";
}

<h2>Daftar Anggota Perpustakaan</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <i class="glyphicon glyphicon-ok-sign"></i> @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <i class="glyphicon glyphicon-exclamation-sign"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="row" style="margin-bottom: 15px;">
    <div class="col-md-6">
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="glyphicon glyphicon-plus"></i> Tambah Anggota Baru
        </a>
        <a href="@Url.Action("Index", "Home")" class="btn btn-default">
            <i class="glyphicon glyphicon-arrow-left"></i> Kembali ke Dashboard
        </a>
    </div>
    <div class="col-md-6">
        @using (Html.BeginForm("Index", "Anggota", FormMethod.Get, new { @class = "form-inline pull-right" }))
        {
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Cari nama, alamat, telepon..." value="@ViewBag.SearchKeyword" style="width: 300px;">
                <span class="input-group-btn">
                    <button class="btn btn-default" type="submit">
                        <i class="glyphicon glyphicon-search"></i> Cari
                    </button>
                </span>
            </div>
            
            if (!string.IsNullOrEmpty(ViewBag.SearchKeyword as string))
            {
                <a href="@Url.Action("Index")" class="btn btn-link">
                    <i class="glyphicon glyphicon-remove"></i> Reset
                </a>
            }
        }
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nama Anggota</th>
            <th>Alamat</th>
            <th>Telepon</th>
            <th>Tanggal Daftar</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.id_anggota</td>
                    <td>@item.nama_anggota</td>
                    <td>@item.alamat</td>
                    <td>@item.telp</td>
                    <td>@(item.tanggal_daftar.HasValue ? item.tanggal_daftar.Value.ToString("dd MMM yyyy") : "-")</td>
                    <td>
                        <a href="@Url.Action("Edit", new { id = item.id_anggota })" class="btn btn-warning btn-sm">
                            <i class="glyphicon glyphicon-pencil"></i> Edit
                        </a>
                        @using (Html.BeginForm("DeleteConfirmed", "Anggota", new { id = item.id_anggota }, FormMethod.Post, new { style = "display:inline;" }))
                        {
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Yakin ingin menghapus anggota ini?')">
                                <i class="glyphicon glyphicon-trash"></i> Hapus
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">
                    @{
                        if (!string.IsNullOrEmpty(ViewBag.SearchKeyword as string))
                        {
                            <text>Tidak ada anggota yang sesuai dengan pencarian "<strong>@ViewBag.SearchKeyword</strong>"</text>
                        }
                        else
                        {
                            <text>Tidak ada data anggota</text>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
